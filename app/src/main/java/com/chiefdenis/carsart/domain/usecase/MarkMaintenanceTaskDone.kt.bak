package com.chiefdenis.carsart.domain.usecase

import com.chiefdenis.carsart.data.repository.MaintenanceRepository
import java.util.UUID
import javax.inject.Inject

class MarkMaintenanceTaskDone @Inject constructor(
    private val maintenanceRepository: MaintenanceRepository
) {
    suspend operator fun invoke(taskId: UUID, currentMileage: Int): Boolean {
        return maintenanceRepository.markTaskAsDone(taskId, currentMileage)
    }
}
